{
  "name": "obsidian-agent-os",
  "version": "0.1.1-beta",
  "private": false,
  "description": "Obsidian Agent OS (beta): Vault-native Obsidian agent + soul loops (thoughts, insights, care). Inspired by Cola; not affiliated.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cht-114514/obsidian-agent-os.git"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "agent",
    "openclaw",
    "grok",
    "rag",
    "second-brain"
  ],
  "workspaces": [
    "packages/*",
    "plugin"
  ],
  "scripts": {
    "test": "npm run test -w @obsidian-agent-os/protocol && npm run test -w obsidian-agent-os-plugin && node --test skills/tests/*.test.js",
    "test:protocol": "npm run test -w @obsidian-agent-os/protocol",
    "test:plugin": "npm run test -w obsidian-agent-os-plugin",
    "build:plugin": "npm run build -w obsidian-agent-os-plugin",
    "skill:digest": "node skills/me-digest/run.mjs",
    "skill:insight": "node skills/me-write-insight/run.mjs",
    "skill:care": "node skills/me-care-check/run.mjs",
    "skill:apply-pending": "node skills/me-apply-pending/run.mjs",
    "skill:apply-insight": "node skills/me-apply-insight/run.mjs"
  }
